<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.collections.FXCollections?>

<VBox spacing="16" style="-fx-padding: 0;"
      xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/21"
      fx:controller="lk.ijse.sams.controller.StudentController">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="12">
        <Label text="Manage Students"
               style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #7f1d1d;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <TextField fx:id="txtSearch" prefWidth="240" prefHeight="36"
                   promptText="🔍  Search students..."
                   style="-fx-border-color: #fecaca; -fx-border-width: 1.5;
                          -fx-border-radius: 8; -fx-background-radius: 8;
                          -fx-padding: 0 12; -fx-font-size: 13px;"/>
        <Button onAction="#handleNew" text="+ New Student"
                style="-fx-background-color: #b91c1c; -fx-text-fill: white;
                       -fx-font-weight: bold; -fx-font-size: 13px;
                       -fx-background-radius: 8; -fx-cursor: hand;
                       -fx-padding: 8 18;"/>
    </HBox>

    <!-- Main card -->
    <HBox spacing="16" VBox.vgrow="ALWAYS">

        <!-- Form Card -->
        <VBox spacing="14" prefWidth="320"
              style="-fx-background-color: white; -fx-background-radius: 14;
                     -fx-padding: 22; -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.07),10,0,0,3);">
            <Label text="Student Details"
                   style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #991b1b;"/>

            <VBox spacing="4">
                <Label text="Student ID" style="-fx-font-size: 12px; -fx-text-fill: #374151; -fx-font-weight: bold;"/>
                <TextField fx:id="txtStudentId" prefHeight="36" editable="false"
                           style="-fx-border-color: #e5e7eb; -fx-border-radius: 7;
                                  -fx-background-radius: 7; -fx-font-size: 13px;
                                  -fx-background-color: #f9fafb;"/>
            </VBox>
            <VBox spacing="4">
                <Label text="Reg. Number" style="-fx-font-size: 12px; -fx-text-fill: #374151; -fx-font-weight: bold;"/>
                <TextField fx:id="txtRegNumber" prefHeight="36"
                           style="-fx-border-color: #fecaca; -fx-border-radius: 7;
                                  -fx-background-radius: 7; -fx-font-size: 13px;"/>
            </VBox>
            <VBox spacing="4">
                <Label text="Full Name" style="-fx-font-size: 12px; -fx-text-fill: #374151; -fx-font-weight: bold;"/>
                <TextField fx:id="txtName" prefHeight="36" promptText="e.g. Kamal Perera"
                           style="-fx-border-color: #fecaca; -fx-border-radius: 7;
                                  -fx-background-radius: 7; -fx-font-size: 13px;"/>
            </VBox>
            <VBox spacing="4">
                <Label text="Email" style="-fx-font-size: 12px; -fx-text-fill: #374151; -fx-font-weight: bold;"/>
                <TextField fx:id="txtEmail" prefHeight="36" promptText="student@email.com"
                           style="-fx-border-color: #fecaca; -fx-border-radius: 7;
                                  -fx-background-radius: 7; -fx-font-size: 13px;"/>
            </VBox>
            <VBox spacing="4">
                <Label text="Phone" style="-fx-font-size: 12px; -fx-text-fill: #374151; -fx-font-weight: bold;"/>
                <TextField fx:id="txtPhone" prefHeight="36" promptText="0771234567"
                           style="-fx-border-color: #fecaca; -fx-border-radius: 7;
                                  -fx-background-radius: 7; -fx-font-size: 13px;"/>
            </VBox>
            <VBox spacing="4">
                <Label text="Address" style="-fx-font-size: 12px; -fx-text-fill: #374151; -fx-font-weight: bold;"/>
                <TextField fx:id="txtAddress" prefHeight="36"
                           style="-fx-border-color: #fecaca; -fx-border-radius: 7;
                                  -fx-background-radius: 7; -fx-font-size: 13px;"/>
            </VBox>
            <VBox spacing="4">
                <Label text="Date of Birth" style="-fx-font-size: 12px; -fx-text-fill: #374151; -fx-font-weight: bold;"/>
                <DatePicker fx:id="dpDob" prefHeight="36" prefWidth="276"
                            style="-fx-border-color: #fecaca; -fx-border-radius: 7;
                                   -fx-background-radius: 7; -fx-font-size: 13px;"/>
            </VBox>
            <VBox spacing="4">
                <Label text="Course" style="-fx-font-size: 12px; -fx-text-fill: #374151; -fx-font-weight: bold;"/>
                <ComboBox fx:id="cboCourse" prefHeight="36" prefWidth="276"
                          promptText="Select Course"
                          style="-fx-border-color: #fecaca; -fx-border-radius: 7;
                                 -fx-background-radius: 7; -fx-font-size: 13px;"/>
            </VBox>

            <!-- Error label -->
            <Label fx:id="lblError" wrapText="true"
                   style="-fx-text-fill: #dc2626; -fx-font-size: 11px;" text=""/>

            <!-- Action buttons -->
            <HBox spacing="8">
                <Button fx:id="btnSave" onAction="#handleSave" text="💾  Save"
                        prefWidth="130" prefHeight="38"
                        style="-fx-background-color: #b91c1c; -fx-text-fill: white;
                               -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;"/>
                <Button fx:id="btnUpdate" onAction="#handleUpdate" text="✏  Update"
                        prefWidth="130" prefHeight="38" disable="true"
                        style="-fx-background-color: #d97706; -fx-text-fill: white;
                               -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;"/>
            </HBox>
            <HBox spacing="8">
                <Button fx:id="btnDelete" onAction="#handleDelete" text="🗑  Delete"
                        prefWidth="130" prefHeight="38" disable="true"
                        style="-fx-background-color: #dc2626; -fx-text-fill: white;
                               -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;"/>
                <Button fx:id="btnClear" onAction="#handleClear" text="↺  Clear"
                        prefWidth="130" prefHeight="38"
                        style="-fx-background-color: #6b7280; -fx-text-fill: white;
                               -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;"/>
            </HBox>
        </VBox>

        <!-- Table Card -->
        <VBox spacing="12" HBox.hgrow="ALWAYS"
              style="-fx-background-color: white; -fx-background-radius: 14;
                     -fx-padding: 22; -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.07),10,0,0,3);">
            <HBox alignment="CENTER_LEFT">
                <Label text="Student List"
                       style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #991b1b;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="lblCount"
                       style="-fx-font-size: 12px; -fx-text-fill: #6b7280;" text="0 records"/>
            </HBox>
            <TableView fx:id="tblStudents" VBox.vgrow="ALWAYS"
                       style="-fx-border-color: #fee2e2; -fx-border-radius: 8;
                              -fx-background-radius: 8;">
                <columns>
                    <TableColumn fx:id="colStudentId"  text="ID"          prefWidth="75"/>
                    <TableColumn fx:id="colRegNumber"  text="Reg. No."    prefWidth="130"/>
                    <TableColumn fx:id="colName"       text="Full Name"   prefWidth="160"/>
                    <TableColumn fx:id="colEmail"      text="Email"       prefWidth="180"/>
                    <TableColumn fx:id="colPhone"      text="Phone"       prefWidth="110"/>
                    <TableColumn fx:id="colCourse"     text="Course"      prefWidth="150"/>
                </columns>
                <placeholder>
                    <Label text="No students found. Add your first student →"
                           style="-fx-text-fill: #9ca3af; -fx-font-size: 13px;"/>
                </placeholder>
            </TableView>
        </VBox>
    </HBox>
</VBox>
