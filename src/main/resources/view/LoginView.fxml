<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Line?>

<!-- SAMS Login – Red & White Split Theme -->

<AnchorPane prefHeight="800" prefWidth="1280" style="-fx-background-color: #fff5f5;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.sams.controller.LoginController">

    <HBox AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">

        <!-- LEFT: Deep Red Gradient Branding Panel -->
        <VBox alignment="CENTER" spacing="0" style="-fx-background-color: linear-gradient(to bottom right, #7f1d1d, #991b1b, #b91c1c, #dc2626, #ef4444);                      -fx-padding: 60 60;" HBox.hgrow="ALWAYS">
            <VBox alignment="CENTER" spacing="24">

                <!-- Logo / Icon -->
                <Label style="-fx-font-size: 78px;                               -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.35), 20, 0, 0, 6);" text="🎓" />

                <!-- App Name Block -->
                <VBox alignment="CENTER" spacing="8">
                    <Label style="-fx-font-size: 52px; -fx-font-weight: bold;                                   -fx-text-fill: white;                                   -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.25),10,0,0,3);" text="SAMS" />
                    <Label style="-fx-font-size: 15px; -fx-text-fill: #fecaca; -fx-font-weight: bold;" text="Student Attendance Management System" />
                    <Label style="-fx-font-size: 13px; -fx-text-fill: #fca5a5;" text="Empowering Education Through Smart Tracking" />
                </VBox>

                <!-- Decorative Divider -->
                <HBox alignment="CENTER" spacing="14" style="-fx-padding: 4 0;">
                    <Line endX="60" startX="0" style="-fx-stroke: rgba(252,165,165,0.55); -fx-stroke-width: 1.5;" />
                    <Label style="-fx-text-fill: #fca5a5; -fx-font-size: 13px;" text="✦" />
                    <Line endX="60" startX="0" style="-fx-stroke: rgba(252,165,165,0.55); -fx-stroke-width: 1.5;" />
                </HBox>
            </VBox>
        </VBox>

        <!-- RIGHT: Clean White Login Form -->
        <VBox alignment="CENTER" prefWidth="500" style="-fx-background-color: white;                      -fx-effect: dropshadow(gaussian, rgba(127,29,29,0.18), 30, 0, -8, 0);">
            <VBox alignment="TOP_CENTER" spacing="0" style="-fx-padding: 55 52 44 52;">

                <!-- Header -->
                <VBox alignment="CENTER" spacing="6" style="-fx-padding: 0 0 32 0;">
                    <Label style="-fx-font-size: 30px; -fx-font-weight: bold;                                   -fx-text-fill: #7f1d1d;" text="Welcome Back 👋" />
                    <Label style="-fx-font-size: 13px; -fx-text-fill: #6b7280;" text="Sign in to your account to continue" />
                </VBox>

                <!-- Username Field -->
                <VBox spacing="7" style="-fx-padding: 0 0 18 0;">
                    <Label style="-fx-font-weight: bold; -fx-text-fill: #991b1b; -fx-font-size: 13px;" text="Username" />
                    <TextField fx:id="txtUsername" prefHeight="46" prefWidth="396" promptText="Enter your username" style="-fx-border-color: #fecaca; -fx-border-width: 2;                                       -fx-border-radius: 10; -fx-background-radius: 10;                                       -fx-padding: 0 14; -fx-font-size: 14px;                                       -fx-background-color: #fffafa;" />
                    <Label fx:id="lblUsernameError" style="-fx-text-fill: #dc2626; -fx-font-size: 11px;" text="" />
                </VBox>

                <!-- Password Field -->
                <VBox spacing="7" style="-fx-padding: 0 0 8 0;">
                    <Label style="-fx-font-weight: bold; -fx-text-fill: #991b1b; -fx-font-size: 13px;" text="Password" />
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <PasswordField fx:id="pfPassword" prefHeight="46" prefWidth="342" promptText="Enter your password" style="-fx-border-color: #fecaca; -fx-border-width: 2;                                               -fx-border-radius: 10; -fx-background-radius: 10;                                               -fx-padding: 0 14; -fx-font-size: 14px;                                               -fx-background-color: #fffafa;" />
                        <TextField fx:id="txtPasswordVisible" managed="false" prefHeight="46" prefWidth="342" promptText="Enter your password" style="-fx-border-color: #fecaca; -fx-border-width: 2;                                           -fx-border-radius: 10; -fx-background-radius: 10;                                           -fx-padding: 0 14; -fx-font-size: 14px;                                           -fx-background-color: #fffafa;" visible="false" />
                        <Button fx:id="btnTogglePassword" onAction="#handleTogglePassword" prefHeight="46" prefWidth="46" style="-fx-background-color: #fff5f5;                                        -fx-border-color: #fecaca; -fx-border-width: 2;                                        -fx-border-radius: 10; -fx-background-radius: 10;                                        -fx-cursor: hand; -fx-font-size: 15px;" text="👁" />
                    </HBox>
                    <Label fx:id="lblPasswordError" style="-fx-text-fill: #dc2626; -fx-font-size: 11px;" text="" />
                </VBox>

                <!-- Error message -->
                <Label fx:id="lblError" prefWidth="396" style="-fx-text-fill: #dc2626; -fx-font-size: 12px;                               -fx-padding: 8 14; -fx-background-radius: 8;" text="" wrapText="true" />

                <!-- Login Button -->
                <Button fx:id="btnLogin" onAction="#handleLogin" prefHeight="50" prefWidth="396" style="-fx-background-color: linear-gradient(to right, #b91c1c, #ef4444);                                -fx-text-fill: white; -fx-font-weight: bold;                                -fx-font-size: 15px; -fx-cursor: hand;                                -fx-background-radius: 12;                                -fx-effect: dropshadow(gaussian, rgba(185,28,28,0.45), 16, 0, 0, 5);" text="Sign In  →" />

                <Region prefHeight="16" />

                <!-- Footer -->
                <Label style="-fx-text-fill: #9ca3af; -fx-font-size: 11px;                               -fx-padding: 10 0 0 0;" text="© 2025 SAMS – Student Attendance Management System" />
            </VBox>
        </VBox>
    </HBox>
</AnchorPane>
