<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="16" style="-fx-padding: 0;"
      xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/21"
      fx:controller="lk.ijse.sams.controller.ClassSessionController">

    <HBox alignment="CENTER_LEFT" spacing="12">
        <Label text="Class Scheduling"
               style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #7f1d1d;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button onAction="#handleNew" text="+ Schedule Class"
                style="-fx-background-color: #b91c1c; -fx-text-fill: white; -fx-font-weight: bold;
                       -fx-font-size: 13px; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 8 18;"/>
    </HBox>

    <HBox spacing="16" VBox.vgrow="ALWAYS">
        <VBox spacing="14" prefWidth="310"
              style="-fx-background-color: white; -fx-background-radius: 14;
                     -fx-padding: 22; -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.07),10,0,0,3);">
            <Label text="Session Details"
                   style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #991b1b;"/>

            <VBox spacing="4">
                <Label text="Session ID" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                <TextField fx:id="txtSessionId" prefHeight="36" editable="false"
                           style="-fx-border-color: #e5e7eb; -fx-border-radius: 7; -fx-background-radius: 7; -fx-background-color: #f9fafb;"/>
            </VBox>
            <VBox spacing="4">
                <Label text="Course" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                <ComboBox fx:id="cboCourse" prefHeight="36" prefWidth="266" promptText="Select Course"
                          onAction="#onCourseSelected"
                          style="-fx-border-color: #fecaca; -fx-border-radius: 7; -fx-background-radius: 7;"/>
            </VBox>
            <VBox spacing="4">
                <Label text="Subject" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                <ComboBox fx:id="cboSubject" prefHeight="36" prefWidth="266" promptText="Select Subject"
                          style="-fx-border-color: #fecaca; -fx-border-radius: 7; -fx-background-radius: 7;"/>
            </VBox>
            <VBox spacing="4">
                <Label text="Lecturer" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                <ComboBox fx:id="cboLecturer" prefHeight="36" prefWidth="266" promptText="Select Lecturer"
                          style="-fx-border-color: #fecaca; -fx-border-radius: 7; -fx-background-radius: 7;"/>
            </VBox>
            <VBox spacing="4">
                <Label text="Session Date" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                <DatePicker fx:id="dpSessionDate" prefHeight="36" prefWidth="266"
                            style="-fx-border-color: #fecaca; -fx-border-radius: 7; -fx-background-radius: 7;"/>
            </VBox>
            <HBox spacing="10">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="Start Time" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                    <TextField fx:id="txtStartTime" prefHeight="36" promptText="08:00"
                               style="-fx-border-color: #fecaca; -fx-border-radius: 7; -fx-background-radius: 7;"/>
                </VBox>
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="End Time" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                    <TextField fx:id="txtEndTime" prefHeight="36" promptText="10:00"
                               style="-fx-border-color: #fecaca; -fx-border-radius: 7; -fx-background-radius: 7;"/>
                </VBox>
            </HBox>
            <VBox spacing="4">
                <Label text="Venue" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                <TextField fx:id="txtVenue" prefHeight="36" promptText="e.g. Hall A, Room 101"
                           style="-fx-border-color: #fecaca; -fx-border-radius: 7; -fx-background-radius: 7;"/>
            </VBox>

            <Label fx:id="lblError" wrapText="true" style="-fx-text-fill: #dc2626; -fx-font-size: 11px;" text=""/>

            <HBox spacing="8">
                <Button fx:id="btnSave" onAction="#handleSave" text="💾  Save"
                        prefWidth="118" prefHeight="38"
                        style="-fx-background-color: #b91c1c; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;"/>
                <Button fx:id="btnUpdate" onAction="#handleUpdate" text="✏  Update"
                        prefWidth="118" prefHeight="38" disable="true"
                        style="-fx-background-color: #d97706; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;"/>
            </HBox>
            <HBox spacing="8">
                <Button fx:id="btnDelete" onAction="#handleDelete" text="🗑  Delete"
                        prefWidth="118" prefHeight="38" disable="true"
                        style="-fx-background-color: #dc2626; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;"/>
                <Button onAction="#handleClear" text="↺  Clear"
                        prefWidth="118" prefHeight="38"
                        style="-fx-background-color: #6b7280; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;"/>
            </HBox>
        </VBox>

        <VBox spacing="12" HBox.hgrow="ALWAYS"
              style="-fx-background-color: white; -fx-background-radius: 14;
                     -fx-padding: 22; -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.07),10,0,0,3);">
            <Label text="Scheduled Classes" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #991b1b;"/>
            <TableView fx:id="tblSessions" VBox.vgrow="ALWAYS"
                       style="-fx-border-color: #fee2e2; -fx-border-radius: 8; -fx-background-radius: 8;">
                <columns>
                    <TableColumn fx:id="colId"       text="ID"         prefWidth="80"/>
                    <TableColumn fx:id="colDate"     text="Date"       prefWidth="110"/>
                    <TableColumn fx:id="colSubject"  text="Subject"    prefWidth="160"/>
                    <TableColumn fx:id="colLecturer" text="Lecturer"   prefWidth="140"/>
                    <TableColumn fx:id="colVenue"    text="Venue"      prefWidth="110"/>
                    <TableColumn fx:id="colStart"    text="Start"      prefWidth="80"/>
                    <TableColumn fx:id="colEnd"      text="End"        prefWidth="80"/>
                </columns>
                <placeholder><Label text="No sessions scheduled." style="-fx-text-fill: #9ca3af;"/></placeholder>
            </TableView>
        </VBox>
    </HBox>
</VBox>
