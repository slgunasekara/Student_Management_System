<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="16" style="-fx-padding: 0;"
      xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/21"
      fx:controller="lk.ijse.sams.controller.ReportController">

    <Label text="Attendance Reports"
           style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #7f1d1d;"/>

    <!-- Filter Bar -->
    <VBox style="-fx-background-color: white; -fx-background-radius: 12;
                 -fx-padding: 18 20; -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.07),8,0,0,2);" spacing="12">
        <Label text="Filter Options"
               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #991b1b;"/>
        <HBox spacing="14" alignment="CENTER_LEFT">
            <VBox spacing="4">
                <Label text="Report Type" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                <ComboBox fx:id="cboReportType" prefHeight="36" prefWidth="180"
                          onAction="#onReportTypeChanged"
                          style="-fx-border-color: #fecaca; -fx-border-radius: 7; -fx-background-radius: 7;"/>
            </VBox>
            <VBox spacing="4">
                <Label text="Course" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                <ComboBox fx:id="cboCourse" prefHeight="36" prefWidth="180" promptText="All Courses"
                          onAction="#onCourseChanged"
                          style="-fx-border-color: #fecaca; -fx-border-radius: 7; -fx-background-radius: 7;"/>
            </VBox>
            <VBox spacing="4">
                <Label text="Student" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                <ComboBox fx:id="cboStudent" prefHeight="36" prefWidth="180" promptText="All Students"
                          style="-fx-border-color: #fecaca; -fx-border-radius: 7; -fx-background-radius: 7;"/>
            </VBox>
            <VBox spacing="4">
                <Label text="From Date" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                <DatePicker fx:id="dpFrom" prefHeight="36" prefWidth="150"
                            style="-fx-border-color: #fecaca; -fx-border-radius: 7; -fx-background-radius: 7;"/>
            </VBox>
            <VBox spacing="4">
                <Label text="To Date" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                <DatePicker fx:id="dpTo" prefHeight="36" prefWidth="150"
                            style="-fx-border-color: #fecaca; -fx-border-radius: 7; -fx-background-radius: 7;"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <VBox spacing="4" alignment="BOTTOM_CENTER">
                <Label text=" " style="-fx-font-size: 12px;"/>
                <Button onAction="#generateReport" text="🔎  Generate"
                        prefHeight="36" prefWidth="120"
                        style="-fx-background-color: #b91c1c; -fx-text-fill: white; -fx-font-weight: bold;
                               -fx-background-radius: 8; -fx-cursor: hand;"/>
            </VBox>
        </HBox>
    </VBox>

    <!-- Summary Chips -->
    <HBox spacing="12">
        <VBox spacing="4" style="-fx-background-color: #fff1f2; -fx-background-radius: 10; -fx-padding: 12 18;">
            <Label text="Total Sessions" style="-fx-font-size: 11px; -fx-text-fill: #991b1b;"/>
            <Label fx:id="lblTotalSessions" text="—"
                   style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #b91c1c;"/>
        </VBox>
        <VBox spacing="4" style="-fx-background-color: #f0fdf4; -fx-background-radius: 10; -fx-padding: 12 18;">
            <Label text="Present Count" style="-fx-font-size: 11px; -fx-text-fill: #166534;"/>
            <Label fx:id="lblPresentCount" text="—"
                   style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #16a34a;"/>
        </VBox>
        <VBox spacing="4" style="-fx-background-color: #fef2f2; -fx-background-radius: 10; -fx-padding: 12 18;">
            <Label text="Absent Count" style="-fx-font-size: 11px; -fx-text-fill: #991b1b;"/>
            <Label fx:id="lblAbsentCount" text="—"
                   style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #dc2626;"/>
        </VBox>
        <VBox spacing="4" style="-fx-background-color: #fffbeb; -fx-background-radius: 10; -fx-padding: 12 18;">
            <Label text="Attendance %" style="-fx-font-size: 11px; -fx-text-fill: #92400e;"/>
            <Label fx:id="lblAttendancePercent" text="—"
                   style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #d97706;"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Button onAction="#exportReport" text="⬇  Export CSV"
                style="-fx-background-color: #1d4ed8; -fx-text-fill: white; -fx-font-weight: bold;
                       -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 10 18;"/>
    </HBox>

    <!-- Report Table -->
    <VBox VBox.vgrow="ALWAYS"
          style="-fx-background-color: white; -fx-background-radius: 14;
                 -fx-padding: 18; -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.07),10,0,0,3);">
        <TableView fx:id="tblReport" VBox.vgrow="ALWAYS"
                   style="-fx-border-color: #fee2e2; -fx-border-radius: 8; -fx-background-radius: 8;">
            <columns>
                <TableColumn fx:id="colStudentId"   text="Student ID"      prefWidth="100"/>
                <TableColumn fx:id="colRegNo"       text="Reg. No."        prefWidth="120"/>
                <TableColumn fx:id="colName"        text="Student Name"    prefWidth="160"/>
                <TableColumn fx:id="colCourse"      text="Course"          prefWidth="140"/>
                <TableColumn fx:id="colSubject"     text="Subject"         prefWidth="160"/>
                <TableColumn fx:id="colDate"        text="Date"            prefWidth="110"/>
                <TableColumn fx:id="colStatus"      text="Status"          prefWidth="100"/>
                <TableColumn fx:id="colPercent"     text="Attend. %"       prefWidth="100"/>
            </columns>
            <placeholder>
                <Label text="Configure filters and click Generate to view report."
                       style="-fx-text-fill: #9ca3af; -fx-font-size: 13px;"/>
            </placeholder>
        </TableView>
    </VBox>
</VBox>
